def json_attesting_indices(obj: raw_ptr[NativeSszObject], node: i32, data: gc_ptr[u8], cap: i32, pos: i32) -> i32:
    value = obj.nodes[node]
    count = value.data_length // value.active_length
    pos = put(data, cap, pos, u8(91))
    i: i32 = 0
    while i < count:
        if i > 0:
            pos = put(data, cap, pos, u8(44))
        pos = json_uint_range(obj, value.data_offset + i * value.active_length, value.active_length, data, cap, pos)
        i = i + 1
    return put(data, cap, pos, u8(93))


