    pos = json_execution_requests(obj, child(obj, node, 12), data, cap, pos)
    return put(data, cap, pos, u8(125))


def json_beacon_block(obj: raw_ptr[NativeSszObject], node: i32, data: gc_ptr[u8], cap: i32, pos: i32) -> i32:
    pos = put(data, cap, pos, u8(123))
    pos = json_key(data, cap, pos, b"slot")
    pos = json_uint(obj, child(obj, node, 0), data, cap, pos)
    pos = put(data, cap, pos, u8(44))
    pos = json_key(data, cap, pos, b"proposer_index")
    pos = json_uint(obj, child(obj, node, 1), data, cap, pos)
    pos = put(data, cap, pos, u8(44))
    pos = json_key(data, cap, pos, b"parent_root")
    pos = json_hex_node(obj, child(obj, node, 2), data, cap, pos)
    pos = put(data, cap, pos, u8(44))
    pos = json_key(data, cap, pos, b"state_root")
    pos = json_hex_node(obj, child(obj, node, 3), data, cap, pos)
    pos = put(data, cap, pos, u8(44))
    pos = json_key(data, cap, pos, b"body")
    pos = json_block_body(obj, child(obj, node, 4), data, cap, pos)
    return put(data, cap, pos, u8(125))


def json_signed_block(obj: raw_ptr[NativeSszObject], node: i32, data: gc_ptr[u8], cap: i32, pos: i32) -> i32:
    pos = put_literal(data, cap, pos, b"{\"message\":")
    pos = json_beacon_block(obj, child(obj, node, 0), data, cap, pos)
    pos = put(data, cap, pos, u8(44))
    pos = json_key(data, cap, pos, b"signature")
    pos = json_hex_node(obj, child(obj, node, 1), data, cap, pos)
    return put(data, cap, pos, u8(125))


def electra_json_size(obj: raw_ptr[NativeSszObject]) -> i32:
    pos = put_literal(obj.root.data, 0, 0, b"{\"data\":")
    pos = json_signed_block(obj, obj.root_node, obj.root.data, 0, pos)
    return put(obj.root.data, 0, pos, u8(125))


def electra_encode_json(obj: raw_ptr[NativeSszObject], output: bytes) -> i32:
    out = BytesObject.from_bytes(output)
    pos = put_literal(out.data, out.length, 0, b"{\"data\":")
    pos = json_signed_block(obj, obj.root_node, out.data, out.length, pos)
    return put(out.data, out.length, pos, u8(125))
