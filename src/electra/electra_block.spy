"""Electra JSON-to-SPy block schema shared structurally with Fulu."""

from unsafe import raw_ptr
from decode_status import DECODE_STATUS_MALFORMED_INPUT, DECODE_STATUS_VALID
from json_parser import (
    JsonDocument,
    array_get,
    array_length,
    decode_json,
    mark_expected_fields,
    object_get,
    require_recognized_object_fields,
)
from metadata import OBJECT_SIGNED_BEACON_BLOCK
from json_lowering import (
    JsonDecodeResult,
    attestation_data,
    eth1_data,
    execution_payload,
    fixed_bytes_list,
    hex_nibble,
    json_bitlist,
    json_bitvector,
    json_fixed_bytes,
    json_uint64,
    sync_aggregate,
)
from ssz_object import (
    KIND_CONTAINER,
    KIND_LIST,
    SszObject,
    add_basic_list_node,
    add_composite_node,
    alloc_data,
    alloc_zeroed_data,
    configure_preset,
    new_object,
    reserve_edges,
    set_edge,
)


def json_uint_data(
    document: raw_ptr[JsonDocument],
    token_index: i32,
    obj: raw_ptr[SszObject],
    size: i32,
) -> i32:
    offset = alloc_zeroed_data(obj, size)
    if offset < 0 or document.status != DECODE_STATUS_VALID:
        obj.status = DECODE_STATUS_MALFORMED_INPUT
        return offset
    token = document.tokens[token_index]
    if token.end <= token.start:
        obj.status = DECODE_STATUS_MALFORMED_INPUT
        return offset
    if (
        token.end - token.start >= 2
        and document.json[token.start] == u8(48)
        and document.json[token.start + 1] == u8(120)
    ):
        digits = token.end - token.start - 2
        if digits % 2 != 0 or digits > size * 2:
            obj.status = DECODE_STATUS_MALFORMED_INPUT
            return offset
        byte_count = digits // 2
        hex_j: i32 = 0
        while hex_j < byte_count:
            high = hex_nibble(document.json[token.start + 2 + hex_j * 2])
            low = hex_nibble(document.json[token.start + 3 + hex_j * 2])
            if high < 0 or low < 0:
                obj.status = DECODE_STATUS_MALFORMED_INPUT
            obj.arena[offset + hex_j] = u8(high * 16 + low)
            hex_j = hex_j + 1
        return offset
    if (
        token.end - token.start > 1
        and document.json[token.start] == u8(48)
    ):
        obj.status = DECODE_STATUS_MALFORMED_INPUT
        return offset
    i = token.start
    while i < token.end:
        digit = i32(document.json[i]) - 48
        if digit < 0 or digit > 9:
            obj.status = DECODE_STATUS_MALFORMED_INPUT
            return offset
        carry = digit
        j: i32 = 0
        while j < size:
            value = i32(obj.arena[offset + j]) * 10 + carry
            obj.arena[offset + j] = u8(value & 255)
            carry = value >> 8
            j = j + 1
        if carry != 0:
            obj.status = DECODE_STATUS_MALFORMED_INPUT
        i = i + 1
    return offset


def block_header(
    document: raw_ptr[JsonDocument], value: i32, obj: raw_ptr[SszObject]
) -> i32:
    first = reserve_edges(obj, 5)
    set_edge(obj, first, 0, json_uint64(document, object_get(document, value, b"slot"), obj))
    set_edge(obj, first, 1, json_uint64(document, object_get(document, value, b"proposer_index"), obj))
    set_edge(obj, first, 2, json_fixed_bytes(document, object_get(document, value, b"parent_root"), obj, 32))
    set_edge(obj, first, 3, json_fixed_bytes(document, object_get(document, value, b"state_root"), obj, 32))
    set_edge(obj, first, 4, json_fixed_bytes(document, object_get(document, value, b"body_root"), obj, 32))
    return add_composite_node(obj, KIND_CONTAINER, first, 5, 5, 0, 0)


def signed_block_header(
    document: raw_ptr[JsonDocument], value: i32, obj: raw_ptr[SszObject]
) -> i32:
    first = reserve_edges(obj, 2)
    set_edge(obj, first, 0, block_header(document, object_get(document, value, b"message"), obj))
    set_edge(obj, first, 1, json_fixed_bytes(document, object_get(document, value, b"signature"), obj, 96))
    return add_composite_node(obj, KIND_CONTAINER, first, 2, 2, 0, 0)


def proposer_slashing(
    document: raw_ptr[JsonDocument], value: i32, obj: raw_ptr[SszObject]
) -> i32:
    first = reserve_edges(obj, 2)
    set_edge(obj, first, 0, signed_block_header(document, object_get(document, value, b"signed_header_1"), obj))
    set_edge(obj, first, 1, signed_block_header(document, object_get(document, value, b"signed_header_2"), obj))
    return add_composite_node(obj, KIND_CONTAINER, first, 2, 2, 0, 0)


def proposer_slashing_list(
    document: raw_ptr[JsonDocument], values: i32, obj: raw_ptr[SszObject]
) -> i32:
    count = array_length(document, values)
    if count > obj.max_proposer_slashings:
        obj.status = DECODE_STATUS_MALFORMED_INPUT
    first = reserve_edges(obj, count)
    i: i32 = 0
    while i < count:
        set_edge(obj, first, i, proposer_slashing(document, array_get(document, values, i), obj))
        i = i + 1
    return add_composite_node(obj, KIND_LIST, first, count, obj.max_proposer_slashings, 0, 0)


def attesting_indices(
    document: raw_ptr[JsonDocument], values: i32, obj: raw_ptr[SszObject]
) -> i32:
    count = array_length(document, values)
    limit = obj.max_validators_per_committee * obj.max_committees_per_slot
    if count > limit:
        obj.status = DECODE_STATUS_MALFORMED_INPUT
        return add_basic_list_node(obj, 0, count, 8, limit)
    offset = alloc_data(obj, count * 8)
    if offset < 0:
        return add_basic_list_node(obj, offset, count, 8, limit)
    i: i32 = 0
    while i < count:
        source = json_uint_data(document, array_get(document, values, i), obj, 8)
        j: i32 = 0
        while j < 8:
            obj.arena[offset + i * 8 + j] = obj.arena[source + j]
            j = j + 1
        i = i + 1
    return add_basic_list_node(obj, offset, count, 8, limit)


def indexed_attestation(
    document: raw_ptr[JsonDocument], value: i32, obj: raw_ptr[SszObject]
) -> i32:
    first = reserve_edges(obj, 3)
    set_edge(obj, first, 0, attesting_indices(document, object_get(document, value, b"attesting_indices"), obj))
    set_edge(obj, first, 1, attestation_data(document, object_get(document, value, b"data"), obj))
    set_edge(obj, first, 2, json_fixed_bytes(document, object_get(document, value, b"signature"), obj, 96))
    return add_composite_node(obj, KIND_CONTAINER, first, 3, 3, 0, 0)


def attester_slashing(
    document: raw_ptr[JsonDocument], value: i32, obj: raw_ptr[SszObject]
) -> i32:
    first = reserve_edges(obj, 2)
    set_edge(obj, first, 0, indexed_attestation(document, object_get(document, value, b"attestation_1"), obj))
    set_edge(obj, first, 1, indexed_attestation(document, object_get(document, value, b"attestation_2"), obj))
    return add_composite_node(obj, KIND_CONTAINER, first, 2, 2, 0, 0)


def attester_slashing_list(
    document: raw_ptr[JsonDocument], values: i32, obj: raw_ptr[SszObject]
